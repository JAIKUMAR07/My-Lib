# Server Configuration
PORT=5000
FRONTEND_URL=http://localhost:5173

# Supabase Configuration
# Replace with your actual Supabase project URL (Project Settings > API)
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL

# IMPORTANT: Key used for backend operations (Project Settings > API > service_role)
# Keep this secret! DO NOT share this in front-end code.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# JWT Secret (Project Settings > API > JWT Secret)
# Used for backend token verification if needed
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET

# DB Connection String (Project Settings > Database > Connection string)
# Optional: Only if choosing to use a traditional ORM or direct PG connection
# DB_CONNECTION_STRING=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres